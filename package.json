{
  "name": "r2jc-web",
  "version": "0.1.0",
  "private": true,
  "description": "R2JC — Rencontre de Jeunes Créateurs. A platform for emerging Swiss creators.",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "npm run clean && next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\""
  },
  "dependencies": {
    "gsap": "3.12.5",
    "lenis": "1.1.20",
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.6",
    "postcss": "8.5.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  }
}
